# ─── Admin Auth ────────────────────────────────────────────────────────────────
# Password used to obtain a JWT token via POST /api/admin/login
ADMIN_PASSWORD="change_me_in_production"

# Secret used to sign and verify JWT tokens (use a long random string)
JWT_SECRET="change_me_to_a_random_256bit_secret"

# ─── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string (e.g. from MongoDB Atlas)
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/cutpricebot?retryWrites=true&w=majority"

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Vercel dashboard domain — only this origin will be allowed by the CORS policy
DASHBOARD_URL="https://your-dashboard.vercel.app"

# ─── Frontend API URL ──────────────────────────────────────────────────────────
# REQUIRED for production builds. The Vite frontend bakes this value in at build
# time (import.meta.env.VITE_API_URL). If unset, src/lib/api.ts falls back to the
# hardcoded Northflank URL — but that fallback will silently break if the backend
# URL ever changes. Always set this explicitly in every deployment environment.
#
#   Vercel:     set in Project → Settings → Environment Variables
#   Northflank: set in Service → Environment → Variables
#   Replit:     set in Secrets (VITE_API_URL)
#   Local dev:  copy this file to .env and fill in the value below
VITE_API_URL="https://site--cutprice-api--d8w4sfqmrf5q.code.run"

# ─── Optional ──────────────────────────────────────────────────────────────────
# Port for the Express server (defaults to 5000)
PORT=5000

# Gemini AI key (if AI features are used)
GEMINI_API_KEY="your_gemini_api_key_here"
